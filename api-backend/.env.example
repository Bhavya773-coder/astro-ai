PORT=5001
NODE_ENV=production

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DBNAME=Users

# Google OAuth 2.0
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Local LLM Configuration (Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_TIMEOUT=300000
OLLAMA_MAX_RETRIES=2

# Legacy LLM Configuration (for backward compatibility)
LLM_MODEL_ENDPOINT=http://localhost:11434/api/chat
LLM_MODEL_NAME=llama3:latest

JWT_SECRET=CHANGE_ME_SUPER_SECRET
JWT_EXPIRES_IN=7d



# SMTP (use your professional domain mailbox)
# Works with Zoho Mail / Google Workspace / Outlook 365 / custom SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=personalaffiliator@gmail.com
SMTP_PASS=YOUR_16_CHAR_APP_PASSWORD
EMAIL_FROM="AstroAI Support <personalaffiliator@gmail.com>"
EMAIL_REPLY_TO=personalaffiliator@gmail.com



