<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Welcome to AstroAi4u</title>
  </head>
  <body style="margin:0;padding:0;background:#0b1026;font-family:Arial,Helvetica,sans-serif;">
    <div style="max-width:560px;margin:0 auto;padding:28px;">
      <div style="background:#ffffff;border-radius:16px;padding:24px;">
        <h1 style="margin:0 0 12px 0;font-size:22px;color:#111827;">Welcome, {{username}}!</h1>
        <p style="margin:0;color:#374151;font-size:14px;line-height:1.5;">
          Your plan: <strong>{{plan}}</strong>
          <br />
          Joined on: {{date}}
        </p>
      </div>
      <p style="margin:14px 0 0 0;color:#9ca3af;font-size:12px;text-align:center;">
        © {{year}} AstroAi4u
      </p>
    </div>
  </body>
</html>
